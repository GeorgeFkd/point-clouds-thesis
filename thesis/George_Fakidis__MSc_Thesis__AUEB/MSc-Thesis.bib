@article{fu_entropy_2023,
	title = {Entropy by {Neighbor} {Distance} as a {New} {Measure} for {
	         Characterizing} {Spatiotemporal} {Orders} in {Microscopic} {
	         Collective} {Systems}},
	volume = {14},
	issn = {2072-666X},
	url = {https://pmc.ncbi.nlm.nih.gov/articles/PMC10456758/},
	doi = {10.3390/mi14081503},
	abstract = {Collective systems self-organize to form globally ordered
	            spatiotemporal patterns. Finding appropriate measures to
	            characterize the order in these patterns will contribute to
	            our understanding of the principles of self-organization in
	            all collective systems. Here we examine a new measure based
	            on the entropy of the neighbor distance distributions in the
	            characterization of collective patterns. We study three types
	            of systems: a simulated self-propelled boid system, two
	            active colloidal systems, and one centimeter-scale robotic
	            swarm system. In all these systems, the new measure proves
	            sensitive in revealing active phase transitions and in
	            distinguishing steady states. We envision that the entropy by
	            neighbor distance could be useful for characterizing
	            biological swarms such as bird flocks and for designing
	            robotic swarms.},
	number = {8},
	urldate = {2026-01-07},
	journal = {Micromachines},
	author = {Fu, Yulei and Wu, Zongyuan and Zhan, Sirui and Yang, Jiacheng
	          and Gardi, Gaurav and Kishore, Vimal and Malgaretti, Paolo and
	          Wang, Wendong},
	month = jul,
