@article{xu_centerface_2020,
	title = {{CenterFace}: {Joint} {Face} {Detection} and {Alignment} {Using
	         } {Face} as {Point}},
	volume = {2020},
	copyright = {http://creativecommons.org/licenses/by/4.0/},
	issn = {1058-9244, 1875-919X},
	shorttitle = {{CenterFace}},
	url = {https://www.hindawi.com/journals/sp/2020/7845384/},
	doi = {10.1155/2020/7845384},
	abstract = {Face detection and alignment in unconstrained environment is
	            always deployed on edge devices which have limited memory
	            storage and low computing power. This paper proposes a
	            one-stage method named CenterFace to simultaneously predict
	            facial box and landmark location with real-time speed and
	            high accuracy. The proposed method also belongs to the
	            anchor-free category. This is achieved by (a) learning face
	            existing possibility by the semantic maps, (b) learning
	            bounding box, offsets, and five landmarks for each position
	            that potentially contains a face. Specifically, the method
	            can run in real time on a single CPU core and 200 FPS using
	            NVIDIA 2080TI for VGA-resolution images and can
	            simultaneously achieve superior accuracy (WIDER FACE
	            Val/Test-Easy: 0.935/0.932, Medium: 0.924/0.921, Hard:
	            0.875/0.873, and FDDB discontinuous: 0.980 and continuous:
	            0.732).},
	language = {en},
	urldate = {2026-02-10},
	journal = {Scientific Programming},
	author = {Xu, Yuanyuan and Yan, Wan and Yang, Genke and Luo, Jiliang and
