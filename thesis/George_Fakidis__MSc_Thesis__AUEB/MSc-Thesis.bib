@inproceedings{dal_poz_ransac-based_2018,
	title = {Ransac-{Based} {Segmentation} for {Building} {Roof} {Face} {
	         Detection} in {Lidar} {Point} {Cloud}},
	issn = {2153-7003},
	url = {https://ieeexplore.ieee.org/abstract/document/8518502},
	doi = {10.1109/IGARSS.2018.8518502},
	abstract = {This work proposes a method for segmenting the roof planes
	            of buildings in Light Detection and Ranging (LiDAR) data.
	            First, a preprocessing of the point cloud is performed to
	            separate the points belonging to each building. The RANdom
	            SAmple Consensus (RANSAC) method is then used in each
	            building region to identify sets of coplanar points belonging
	            to the roof faces. Finally, planar segments representing the
	            same roof face are connected to minimize the fragmentation
	            that may occur in the previous step. This requires the use of
	            techniques for analyzing the continuity of adjacent planar
	            segments. Although several thresholds are required, they can
	            be predetermined or adapted, thus avoiding their modification
	            by an operator in each application of the method. The results
	            show that the proposed method functions appropriately, rarely
	            failing in regions affected by local structures such as trees
	            and antennas. Consequently, average rates higher than 90\%
	            were obtained for completeness and correction.},
	urldate = {2026-02-10},
	booktitle = {{IGARSS} 2018 - 2018 {IEEE} {International} {Geoscience}
	             and {Remote} {Sensing} {Symposium}},
	author = {Dal Poz, Aluir Porfirio and Yano, Michelle Sayuri},
	month = jul,
	year = {2018},
	note = {ISSN: 2153-7003},
	keywords = {Three-dimensional displays, NAH, Feature extraction, Laser
	            radar, Shape, Antennas, Buildings, Face, LiDAR, RANSAC, roof
	            segmentation},
	pages = {1276--1279},
	file = {Full Text PDF:/home/georgefkd/Zotero/storage/TYDYLQTU/Dal Poz
