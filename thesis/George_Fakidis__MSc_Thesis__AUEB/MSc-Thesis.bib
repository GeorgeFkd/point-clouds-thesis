	keywords = {Three-dimensional displays, Point cloud compression, Deep
	            learning, Transformers, NAH, Cloud computing, Consumer
	            electronics, dual-scale pruning, mobile edge computing,
	            Neural networks, point cloud video, Task analysis,
	            transformer},
