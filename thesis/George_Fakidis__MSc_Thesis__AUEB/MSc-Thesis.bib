	            PointNet, Radar, Radar antennas, Radar imaging, Sensor
	            phenomena and characterization},
	pages = {0074--0083},
	file = {Full Text PDF:/home/georgefkd/Zotero/storage/3L5ZN8ZL/Zhong et
