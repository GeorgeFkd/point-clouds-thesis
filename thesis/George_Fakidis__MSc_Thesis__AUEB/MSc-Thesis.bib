	            table, Nearest neighbor methods, Patch segmentation, Point
	            cloud compression, Real-time systems, Search problems,
	            Transform coding, Video-based Point Cloud Compression},
	pages = {1--5},
	file = {Full Text PDF:/home/georgefkd/Zotero/storage/YDMDTGXP/Kim and
